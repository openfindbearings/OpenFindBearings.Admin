@{ ViewData["Title"] = "审计日志"; }

<div class="card">
    <div class="card-header"><h6 class="mb-0">审计日志</h6></div>
    <div class="card-body p-0">
        <table class="table table-hover">
            <thead><tr><th>用户</th><th>操作</th><th>详情</th><th>时间</th></tr></thead>
            <tbody>
                @{ var items = ViewBag.Items as IEnumerable<AuditLogItemDto> ?? Enumerable.Empty<AuditLogItemDto>(); }
                @if (items.Any())
                {
                    @foreach (var item in items)
                    {
                        <tr>
                            <td>@item.UserName</td>
                            <td>@item.Action</td>
                            <td>@(item.Detail ?? "-")</td>
                            <td>@item.Timestamp.ToString("yyyy-MM-dd HH:mm:ss")</td>
                        </tr>
                    }
                }
                else
                {
                    <tr><td colspan="4" class="text-center text-muted py-4">暂无日志</td></tr>
                }
            </tbody>
        </table>
    </div>
</div>
