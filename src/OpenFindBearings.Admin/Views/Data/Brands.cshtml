@model BrandListViewModel
@{ ViewData["Title"] = "品牌管理"; }

<div class="card">
    <div class="card-header d-flex justify-content-between align-items-center">
        <h6 class="mb-0">品牌管理 <small class="text-muted">(@Model.TotalCount 条)</small></h6>
        <form class="d-flex gap-2" method="get">
            <input type="text" name="search" value="@Model.Search" class="form-control form-control-sm" placeholder="搜索品牌..." />
            <button class="btn btn-sm btn-primary">搜索</button>
        </form>
    </div>
    <div class="card-body p-0">
        <table class="table table-hover">
            <thead><tr><th>名称</th><th>Code</th><th>描述</th></tr></thead>
            <tbody>
                @if (Model.Items.Any())
                {
                    @foreach (var item in Model.Items)
                    {
                        <tr><td>@item.Name</td><td>@(item.Code ?? "-")</td><td>@(item.Description ?? "-")</td></tr>
                    }
                }
                else
                {
                    <tr><td colspan="3" class="text-center text-muted py-4">暂无数据</td></tr>
                }
            </tbody>
        </table>
    </div>
    @if (Model.TotalPages > 1)
    {
        <div class="card-footer">
            <nav><ul class="pagination pagination-sm mb-0">
                @for (var i = 1; i <= Model.TotalPages; i++)
                {
                    <li class="page-item @(i == Model.Page ? "active" : "")">
                        <a class="page-link" href="?page=@i&pageSize=@Model.PageSize&search=@Model.Search">@i</a>
                    </li>
                }
            </ul></nav>
        </div>
    }
</div>
