@{ ViewData["Title"] = "商家认证审核"; }

<div class="card">
    <div class="card-header d-flex justify-content-between align-items-center">
        <h6 class="mb-0">商家认证审核</h6>
        <form class="d-flex gap-2" method="get">
            <input type="text" name="search" value="@ViewBag.Search" class="form-control form-control-sm" placeholder="搜索商家..." />
            <button class="btn btn-sm btn-primary">搜索</button>
        </form>
    </div>
    <div class="card-body p-0">
        <table class="table table-hover">
            <thead><tr><th>名称</th><th>英文名</th><th>联系人</th><th>电话</th><th>操作</th></tr></thead>
            <tbody>
                @{ var items = ViewBag.Items as IEnumerable<MerchantItemDto> ?? Enumerable.Empty<MerchantItemDto>(); }
                @if (items.Any())
                {
                    @foreach (var item in items)
                    {
                        <tr>
                            <td>@item.Name</td>
                            <td>@(item.EnglishName ?? "-")</td>
                            <td>@(item.ContactPerson ?? "-")</td>
                            <td>@(item.Phone ?? "-")</td>
                            <td>
                                <form method="post" asp-action="Verify" asp-route-id="@item.Id" class="d-inline">
                                    <button class="btn btn-sm btn-outline-success">认证</button>
                                </form>
                            </td>
                        </tr>
                    }
                }
                else
                {
                    <tr><td colspan="5" class="text-center text-muted py-4">暂无数据</td></tr>
                }
            </tbody>
        </table>
    </div>
</div>
