@using OpenFindBearings.Admin.Controllers
@{ ViewData["Title"] = "权限列表"; }

<div class="card">
    <div class="card-header">
        <h6 class="mb-0">权限列表 <small class="text-muted">（只读展示，权限键由系统定义）</small></h6>
    </div>
    <div class="card-body">
        @{
            var groups = ViewBag.Groups as IEnumerable<IGrouping<string, PermissionDisplayViewModel>> ?? Enumerable.Empty<IGrouping<string, PermissionDisplayViewModel>>();
        }
        @if (!groups.Any())
        {
            <p class="text-muted">暂无数据</p>
        }
        else
        {
            @foreach (var group in groups)
            {
                <div class="mb-4">
                    <h6 class="text-primary mb-3">@group.Key</h6>
                    <div class="row">
                        @foreach (var perm in group)
                        {
                            <div class="col-md-4 mb-2">
                                <div class="d-flex align-items-center">
                                    <span class="badge bg-secondary me-2" style="font-size: 11px; min-width: 120px;">@perm.Key</span>
                                    <span>@perm.DisplayName</span>
                                </div>
                            </div>
                        }
                    </div>
                </div>
            }
        }
    </div>
</div>
