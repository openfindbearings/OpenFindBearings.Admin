@{ ViewData["Title"] = "用户管理"; }

<div class="card">
    <div class="card-header d-flex justify-content-between align-items-center">
        <h6 class="mb-0">用户管理</h6>
        <form class="d-flex gap-2" method="get">
            <input type="text" name="search" value="@ViewBag.Search" class="form-control form-control-sm" placeholder="搜索用户..." />
            <button class="btn btn-sm btn-primary">搜索</button>
        </form>
    </div>
    <div class="card-body p-0">
        <table class="table table-hover">
            <thead><tr><th>用户名</th><th>邮箱</th><th>状态</th><th>角色</th><th>操作</th></tr></thead>
            <tbody>
                @{ var items = ViewBag.Items as IEnumerable<UserItemDto> ?? Enumerable.Empty<UserItemDto>(); }
                @if (items.Any())
                {
                    @foreach (var item in items)
                    {
                        <tr>
                            <td>@item.UserName</td>
                            <td>@item.Email</td>
                            <td><span class="badge bg-@(item.IsActive?"success":"secondary")">@(item.IsActive?"启用":"禁用")</span></td>
                            <td>@(item.Roles ?? "-")</td>
                            <td>
                                <form method="post" asp-action="ToggleStatus" asp-route-id="@item.Id" class="d-inline">
                                    <button class="btn btn-sm btn-outline-@(item.IsActive?"danger":"success")">@(item.IsActive?"禁用":"启用")</button>
                                </form>
                            </td>
                        </tr>
                    }
                }
                else
                {
                    <tr><td colspan="5" class="text-center text-muted py-4">暂无数据</td></tr>
                }
            </tbody>
        </table>
    </div>
</div>
